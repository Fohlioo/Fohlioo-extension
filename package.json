{
  "name": "fohlioo-extension",
  "displayName": "Fohlioo extension",
  "version": "0.0.1",
  "description": "Fohlioo a two sided AI fashion intelligence platform for both shoppers and brands.",
  "author": "Oyindamola",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "vitest": {
    "environment": "jsdom"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.0",
    "prettier": "3.2.4",
    "stream-browserify": "^3.0.0",
    "typescript": "5.3.3",
    "util": "^0.12.3",
    "vitest": "^4.1.8"
  },
  "manifest": {
    "web_accessible_resources": [
      {
        "resources": [
          "assets/*",
          "*.js",
          "*.css"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ],
    "permissions": [
      "activeTab",
      "scripting",
      "storage"
    ]
  }
}
