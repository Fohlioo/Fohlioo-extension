## SEGMENTATION ENGINE — PHASE 1 RULES

The rule-based engine runs server-side, not in the extension. It is triggered after every event ingestion and recomputes the shopper's segment.

```typescript
interface SegmentResult {
  segment: 'investment_dresser' | 'trend_chaser' | 
           'quiet_minimalist' | 'brand_loyalist' | 'unclassified'
  confidence: number // 0-1
  event_count: number
  signals_used: string[]
}

function classifyShopper(signals: ShopperSignals): SegmentResult {
  const {
    avg_consideration_arc_days,
    dwell_time_p75_ms,
    return_rate,
    full_price_rate,
    brand_hhi_index,
    colour_palette_entropy,
    purchase_frequency_30d,
    avg_order_value,
    event_count
  } = signals

  // Require minimum events before classifying
  if (event_count < 10) {
    return { segment: 'unclassified', confidence: 0, event_count, signals_used: [] }
  }

  // Investment Dresser
  if (
    avg_consideration_arc_days > 7 &&
    dwell_time_p75_ms > 90000 &&
    return_rate < 0.12 &&
    full_price_rate > 0.75
  ) {
    return {
      segment: 'investment_dresser',
      confidence: calculateConfidence([
        avg_consideration_arc_days / 21,
        (90000 / dwell_time_p75_ms) > 1 ? 1 : 90000 / dwell_time_p75_ms,
        1 - return_rate,
        full_price_rate
      ]),
      event_count,
      signals_used: ['consideration_arc', 'dwell_time', 'return_rate', 'full_price_rate']
    }
  }

  // Brand Loyalist
  if (brand_hhi_index > 0.65 && full_price_rate > 0.65) {
    return {
      segment: 'brand_loyalist',
      confidence: calculateConfidence([brand_hhi_index, full_price_rate]),
      event_count,
      signals_used: ['brand_hhi', 'full_price_rate']
    }
  }

  // Quiet Minimalist
  if (colour_palette_entropy < 0.3 && return_rate < 0.08) {
    return {
      segment: 'quiet_minimalist',
      confidence: calculateConfidence([1 - colour_palette_entropy, 1 - return_rate]),
      event_count,
      signals_used: ['colour_entropy', 'return_rate']
    }
  }

  // Trend Chaser
  if (
    avg_consideration_arc_days < 3 &&
    purchase_frequency_30d > 2 &&
    return_rate > 0.25
  ) {
    return {
      segment: 'trend_chaser',
      confidence: calculateConfidence([
        1 - (avg_consideration_arc_days / 3),
        purchase_frequency_30d / 5,
        return_rate
      ]),
      event_count,
      signals_used: ['consideration_arc', 'purchase_frequency', 'return_rate']
    }
  }

  return { segment: 'unclassified', confidence: 0, event_count, signals_used: [] }
}

function calculateConfidence(factors: number[]): number {
  const avg = factors.reduce((a, b) => a + b, 0) / factors.length
  return Math.min(Math.max(avg, 0), 1)
}
```

