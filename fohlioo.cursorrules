## COMPUTED SIGNALS — HOW TO DERIVE THEM

These functions run over the raw events table to produce the shopper_signals row.

```typescript
// Consideration arc — days between first page_view and purchase_confirmed for same product
async function getConsiderationArc(shopperId: string): Promise<number> {
  const { data } = await supabase.rpc('compute_consideration_arc', { 
    p_shopper_id: shopperId 
  })
  return data ?? 0
}

// Brand HHI — Herfindahl-Hirschman Index on brand distribution
// HHI = sum of (brand_share)^2 across all brands
// Score near 1 = highly concentrated (Brand Loyalist)
// Score near 0 = highly distributed
function computeBrandHHI(brandCounts: Record<string, number>): number {
  const total = Object.values(brandCounts).reduce((a, b) => a + b, 0)
  if (total === 0) return 0
  return Object.values(brandCounts)
    .map(count => Math.pow(count / total, 2))
    .reduce((a, b) => a + b, 0)
}

// Colour palette entropy — Shannon entropy on colour distribution
// Low entropy = consistent palette (Quiet Minimalist)
// High entropy = varied palette (Trend Chaser)
function computeColourEntropy(colourCounts: Record<string, number>): number {
  const total = Object.values(colourCounts).reduce((a, b) => a + b, 0)
  if (total === 0) return 0
  return -Object.values(colourCounts)
    .map(count => {
      const p = count / total
      return p > 0 ? p * Math.log2(p) : 0
    })
    .reduce((a, b) => a + b, 0)
}

// Full price rate — proportion of purchases at original price
function computeFullPriceRate(events: Event[]): number {
  const purchases = events.filter(e => e.event_type === 'purchase_confirmed')
  if (purchases.length === 0) return 0
  const fullPrice = purchases.filter(e => 
    !e.original_price || e.price >= e.original_price * 0.95
  )
  return fullPrice.length / purchases.length
}
```

