## DATA EXTRACTION — HOW TO READ JSON-LD

Every major fashion site embeds structured product data for SEO. Read it before any DOM scraping.

```typescript
function extractFromJsonLd(): Partial<ProductData> {
  const scripts = document.querySelectorAll('script[type="application/ld+json"]')
  
  for (const script of scripts) {
    try {
      const raw = JSON.parse(script.textContent || "")
      // Data may be array or single object
      const items = Array.isArray(raw) ? raw : [raw]
      const product = items.find(item => 
        item["@type"] === "Product" || 
        item["@type"] === "IndividualProduct"
      )
      if (!product) continue

      return {
        name: product.name ?? null,
        brand: product.brand?.name ?? product.brand ?? null,
        price: product.offers?.price 
          ? parseFloat(String(product.offers.price)) 
          : null,
        originalPrice: product.offers?.highPrice
          ? parseFloat(String(product.offers.highPrice))
          : null,
        currency: product.offers?.priceCurrency ?? null,
        category: product.category ?? null,
        colour: product.color ?? null,
        image: Array.isArray(product.image) 
          ? product.image[0] 
          : product.image ?? null,
      }
    } catch {
      continue
    }
  }
  return {}
}
```

### Open Graph fallback
```typescript
function extractFromOG(): Partial<ProductData> {
  const get = (prop: string) =>
    document.querySelector(`meta[property="${prop}"]`)
      ?.getAttribute("content") ?? null

  return {
    name:     get("og:title"),
    image:    get("og:image"),
    price:    get("product:price:amount") 
                ? parseFloat(get("product:price:amount")!) 
                : null,
    currency: get("product:price:currency"),
    brand:    get("og:site_name"),
  }
}
```

### SPA navigation handling
Zara, ASOS, and many others are React apps — the URL changes without a full page reload. Always handle this:

```typescript
let lastUrl = location.href
const navObserver = new MutationObserver(() => {
  if (location.href !== lastUrl) {
    lastUrl = location.href
    // Wait 800ms for React to render the new page
    setTimeout(() => capturePageView(), 800)
  }
})
navObserver.observe(document.body, { subtree: true, childList: true })
```

