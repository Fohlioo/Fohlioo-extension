## SUPABASE SCHEMA — BUILD THIS EXACTLY

```sql
-- Enable pgvector
create extension if not exists vector;

-- Shoppers
create table shoppers (
  id uuid primary key default gen_random_uuid(),
  created_at timestamptz default now(),
  email text unique,
  segment text check (segment in (
    'investment_dresser', 'trend_chaser', 
    'quiet_minimalist', 'brand_loyalist', 'unclassified'
  )),
  segment_confidence float default 0,
  event_count integer default 0,
  last_active_at timestamptz
);

-- Sessions
create table sessions (
  id uuid primary key default gen_random_uuid(),
  shopper_id uuid references shoppers(id) on delete cascade,
  started_at timestamptz default now(),
  ended_at timestamptz,
  brand_domain text,
  page_count integer default 0
);

-- Raw events (everything the extension captures)
create table events (
  id uuid primary key default gen_random_uuid(),
  shopper_id uuid references shoppers(id) on delete cascade,
  session_id uuid references sessions(id) on delete cascade,
  event_type text not null check (event_type in (
    'page_view', 'wishlist_add', 'wishlist_remove',
    'add_to_cart', 'cart_abandon', 'size_selected',
    'colour_selected', 'review_section_view',
    'size_guide_view', 'purchase_confirmed',
    'return_initiated', 'scroll_milestone', 'dwell_milestone'
  )),
  product_url text,
  product_name text,
  brand text,
  price numeric,
  original_price numeric,
  currency text default 'GBP',
  category text,
  colour text,
  dwell_time_ms integer,
  scroll_depth_pct float,
  timestamp timestamptz default now(),
  metadata jsonb default '{}'
);

-- Products catalogue (from AWIN + page captures)
create table products (
  id uuid primary key default gen_random_uuid(),
  url text unique not null,
  name text,
  brand text,
  price numeric,
  currency text default 'GBP',
  category text,
  colour text,
  image_url text,
  embedding vector(1536),  -- OpenAI text-embedding-3-small dimension
  last_seen_at timestamptz default now(),
  created_at timestamptz default now()
);

-- Computed shopper signals (derived from raw events, updated periodically)
create table shopper_signals (
  shopper_id uuid primary key references shoppers(id) on delete cascade,
  avg_consideration_arc_days float,
  dwell_time_p75_ms integer,
  return_rate float,
  full_price_rate float,
  brand_hhi_index float,
  colour_palette_entropy float,
  purchase_frequency_30d float,
  avg_order_value numeric,
  unique_brands_30d integer,
  sale_browse_ratio float,
  updated_at timestamptz default now()
);

-- Segment history (track how segments evolve over time)
create table segment_history (
  id uuid primary key default gen_random_uuid(),
  shopper_id uuid references shoppers(id) on delete cascade,
  segment text,
  confidence float,
  computed_at timestamptz default now(),
  event_count_at_time integer
);

-- Row Level Security
alter table shoppers enable row level security;
alter table sessions enable row level security;
alter table events enable row level security;
alter table shopper_signals enable row level security;
alter table segment_history enable row level security;

-- Shoppers can only access their own data
create policy "shoppers_own_data" on shoppers
  for all using (auth.uid() = id);

create policy "sessions_own_data" on sessions
  for all using (auth.uid() = shopper_id);

create policy "events_own_data" on events
  for all using (auth.uid() = shopper_id);

-- Index for performance
create index on events (shopper_id, timestamp desc);
create index on events (product_url, shopper_id);
create index on events (brand, shopper_id);
create index on products using ivfflat (embedding vector_cosine_ops)
  with (lists = 100);
```

